# AI
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_DAILY_CALL_LIMIT=200

# Local Auth
LOCAL_API_TOKEN=auto_generated_on_first_boot

# DB
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading
POSTGRES_DB=trading
POSTGRES_HOST=postgres

# Redis (AOF on)
REDIS_HOST=redis

# Sandbox
SANDBOX_IMAGE=trading-sandbox:latest
SANDBOX_TIMEOUT_SEC=30
SANDBOX_MEMORY=256m
SANDBOX_CPUS=0.5

# Backtest
BACKTEST_MAX_YEARS=5
BACKTEST_MAX_CANDLES=100000
BACKTEST_SYNC_TIMEOUT_SEC=30
